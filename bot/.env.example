# Copia a .env para probar en local (o ponlas como secrets en Fly).
DISCORD_BOT_TOKEN=
# Opcional pero recomendado: id del servidor. Registra los slash commands
# (/apuntar, /desapuntar, /lista-cwl) al instante en ese servidor. Sin él, se
# registran globalmente y tardan ~1h en aparecer.
DISCORD_GUILD_ID=
# Mismos valores que en Vercel:
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Opcional: id del canal de inscripciones para el texto libre (si no, escucha
# todos los canales). Los slash commands funcionan en cualquier canal.
SIGNUP_CHANNEL_ID=
# Opcionales: fallback de config de CWL. Normalmente NO hacen falta: se leen de
# la tabla settings (sembrada por supabase/cwl.sql). Solo por si settings falla.
CWL_LIST_CHANNEL_ID=
CWL_ROLE_ID=
CLAN_ROLE_ID=
